# Optional: enables AI-generated recruiter notes via Gemini 2.5 Flash on /api/explain.
# If unset, the app falls back to a rule-based templated note (no crash, no paid calls).
GEMINI_API_KEY=

# Frontend: base URL of the FastAPI backend. Defaults to http://localhost:8000 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000
